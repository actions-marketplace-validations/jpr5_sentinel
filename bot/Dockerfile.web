FROM ruby:3.3-alpine

RUN apk add --no-cache git && \
    apk add --no-cache --virtual .build-deps build-base && \
    gem install sinatra rackup puma --no-doc && \
    apk del .build-deps

COPY lib/ /sentinel/lib/
COPY bot/ /sentinel/bot/

RUN mkdir -p /sentinel/data

WORKDIR /sentinel

EXPOSE 3000

CMD ["ruby", "bot/web.rb"]
